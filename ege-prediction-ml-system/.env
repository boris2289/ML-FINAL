# Название эксперимента в MLflow UI.
# Если поменять — в MLflow появится новый эксперимент.
EXPERIMENT_NAME=ege-prediction-experiment

# Название конкретного запуска внутри эксперимента.
# Удобно менять при тестах разных гиперпараметров.
RUN_NAME=catboost-ege-prediction

# Имя модели в MLflow Model Registry.
# Используется, если REGISTER_MODEL=true.
MODEL_NAME=ege-catboost-regressor

# Нужно ли регистрировать модель в MLflow Registry после обучения.
# true = регистрировать, false = только залогировать метрики/артефакты.
REGISTER_MODEL=true

# MLflow Tracking URI для локального запуска с Mac.
# Открывается в браузере как http://localhost:5001.
# В docker-compose для training переопределяется на http://mlflow:5001.
MLFLOW_TRACKING_URI=http://localhost:5001

# Имя исходного CSV в папке data/.
# Полный путь получится: data/2025_07_24_el_school.csv
RAW_CSV_FILENAME=2025_07_24_el_school.csv

SUBJECT_FILTER=

# Минимальный валидный балл ЕГЭ.
# Строки ниже этого значения будут отфильтрованы при подготовке данных.
EGE_MIN_SCORE=30

# Максимальный валидный балл ЕГЭ.
# Строки выше этого значения будут отфильтрованы при подготовке данных.
EGE_MAX_SCORE=100

# Разрешенные классы учеников.
# Значения через запятую, без пробелов.
ALLOWED_CLASSES=9,10,11

# Доля тестовой выборки при обучении.
# 0.2 = 20% данных на test, 80% на train.
TEST_SIZE=0.2

# Папка с CSV-файлами.
# В Docker монтируется как /app/data.
DATA_DIR=data

# Папка для сохранения модели и метрик.
# В Docker монтируется как /app/artifacts.
ARTIFACTS_DIR=artifacts


# Количество итераций обучения CatBoost.
ITERATIONS=3000
DEPTH=12
LEARNING_RATE=0.03

# L2-регуляризация листьев CatBoost.
# Помогает бороться с переобучением.
L2_LEAF_REG=7

# Случайность при выборе сплитов.
# Больше значение = больше регуляризация/случайность.
RANDOM_STRENGTH=12
RANDOM_STATE=54

# Функция ошибки для обучения.
# MAE хорошо подходит для задачи прогноза баллов.
LOSS_FUNCTION=MAE

# Целевая переменная — реальный балл ЕГЭ, который модель учится предсказывать.
TARGET_COL=course_student_ege_result

# Категориальные признаки для CatBoost.
# Значения через запятую, без пробелов.
CAT_FEATURES=student_target,student_class,course_name,subject_name
USED_FEATURES=student_target,student_class,course_name,subject_name,homework_done_mark,test_part_one,test_part_two,homework_lag_1,homework_lag_2,test1_lag_1,test2_lag_1,homework_diff,test1_diff,test2_diff,homework_rolling_mean_3,homework_rolling_std_3,test1_rolling_mean_3,test2_rolling_std_3,homework_max,homework_min,test1_max,test1_min,test2_max,test2_min

# Какие lag-периоды строить для временных признаков.
# 1,2 = брать предыдущее и предпредыдущее значение.
LAG_PERIODS=1,2
ROLLING_WINDOW=3


POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Host FastAPI внутри контейнера.
# 0.0.0.0 нужен, чтобы контейнер был доступен снаружи.
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000

# Порт Streamlit UI.
# Открывается на Mac как http://localhost:8501.
STREAMLIT_PORT=8501
BATCH_INTERVAL_SECONDS=300

# Сколько записей обрабатывать за один batch-запуск.
BATCH_LIMIT=100
BATCH_MODEL_VERSION=docker-catboost-v1
DEFAULT_SEED_LIMIT=100

PYTHONPATH=/app
GIT_PYTHON_REFRESH=quiet
