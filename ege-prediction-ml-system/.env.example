# ══════════════════════════════════════════════════════════════
#  EGE Prediction ML System — единый конфиг эксперимента
#  Скопируйте в .env и правьте под новый эксперимент.
# ══════════════════════════════════════════════════════════════

# ── Эксперимент ───────────────────────────────────────────────
EXPERIMENT_NAME=ege-prediction-experiment
RUN_NAME=catboost-ege-prediction
MODEL_NAME=ege-catboost-regressor
REGISTER_MODEL=true

# ── Данные ────────────────────────────────────────────────────
# Путь к исходному CSV (относительно корня проекта)
RAW_CSV_FILENAME=2025_07_24_el_school.csv
# Фильтр по предмету (пусто = все предметы)
SUBJECT_FILTER=
# Балл ЕГЭ: мин/макс
EGE_MIN_SCORE=30
EGE_MAX_SCORE=100
# Классы
ALLOWED_CLASSES=9,10,11
# Размер тестовой выборки
TEST_SIZE=0.2

# ── Гиперпараметры CatBoost ──────────────────────────────────
ITERATIONS=3000
DEPTH=12
LEARNING_RATE=0.03
L2_LEAF_REG=7
RANDOM_STRENGTH=12
RANDOM_STATE=54
LOSS_FUNCTION=MAE

# ── Фичи ─────────────────────────────────────────────────────
# Категориальные фичи (через запятую)
CAT_FEATURES=student_target,student_class,course_name,subject_name

# Все фичи для обучения (через запятую)
USED_FEATURES=student_target,student_class,course_name,subject_name,homework_done_mark,test_part_one,test_part_two,homework_lag_1,homework_lag_2,test1_lag_1,test2_lag_1,homework_diff,test1_diff,test2_diff,homework_rolling_mean_3,homework_rolling_std_3,test1_rolling_mean_3,test2_rolling_std_3,homework_max,homework_min,test1_max,test1_min,test2_max,test2_min

# Целевая переменная
TARGET_COL=course_student_ege_result

# ── Rolling / Lag параметры ───────────────────────────────────
LAG_PERIODS=1,2
ROLLING_WINDOW=3

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ege_predictions
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── MLflow ────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5001

# ── API / Frontend ────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
STREAMLIT_PORT=8501

# ── Batch Scheduler ──────────────────────────────────────────
BATCH_INTERVAL_SECONDS=300
BATCH_LIMIT=100
BATCH_MODEL_VERSION=docker-catboost-v1
DEFAULT_SEED_LIMIT=100

# ── Пути артефактов (относительно корня проекта) ─────────────
DATA_DIR=data
ARTIFACTS_DIR=artifacts
